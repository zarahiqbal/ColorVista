{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  "java.configuration.updateBuildConfiguration": "interactive",
  "json.schemas": [
    {
      "fileMatch": [
        "/app.json"
      ],
      "url": "./.vscode/expo-app.schema.json"
    }
  ]
}
